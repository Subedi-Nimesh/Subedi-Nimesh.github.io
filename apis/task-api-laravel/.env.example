APP_NAME="Task Manager API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=taskapi
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST="${APP_URL}"
